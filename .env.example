# ============================================================================
# PT KARYA NUSANTARA REALTY — Environment Variables
# ============================================================================

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="PT Karya Nusantara Realty"
NEXT_PUBLIC_SITE_DESCRIPTION="World-class luxury architecture firm crafting timeless spaces"
SITE_URL=http://localhost:3000

# Business
NEXT_PUBLIC_COMPANY_PHONE="+62 21 1234 5678"
NEXT_PUBLIC_COMPANY_EMAIL="hello@karyanusantara.com"
NEXT_PUBLIC_COMPANY_ADDRESS="Jakarta, Indonesia"

# Social
NEXT_PUBLIC_SOCIAL_INSTAGRAM="https://instagram.com/karyanusantara"
NEXT_PUBLIC_SOCIAL_LINKEDIN="https://linkedin.com/company/karyanusantara"

# SEO
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ============================================================================
# Supabase — REQUIRED for CMS & backend
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================================
# Storage — Supabase Storage buckets configuration
# ============================================================================
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=media
SUPABASE_STORAGE_MAX_FILE_SIZE=10485760

# ============================================================================
